{
  "name": "altpdf",
  "version": "0.1.2",
  "description": "",
  "main": "./dist/main.js",
  "scripts": {
    "copy": "cp src/renderer/*.html dist/renderer/",
    "build": "tsc && npm run copy",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "test": "jest"
  },
  "build": {
    "appId": "com.altpdf.app",
    "productName": "AltPDF",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "appx"
    },
    "appx": {
      "identityName": "AlanJacobson.AltPdf",
      "publisher": "CN=AlanJacobson, O=jacosr, C=US"
    },
    "fileAssociations": [
      {
        "ext": "apdf",
        "name": "AltPDF File",
        "description": "AltPDF Form Document",
        "role": "Editor"
      }
    ],
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "Alan Jacobson",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/node-forge": "^1.3.14",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "node-forge": "^1.4.0"
  }
}
